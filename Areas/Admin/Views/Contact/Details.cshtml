@model AdmissionWeb.Models.Entities.ContactRequest
@{
    ViewData["Title"] = "Chi tiết Liên hệ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0"><i class="fas fa-envelope-open-text text-primary me-2"></i>Chi tiết Yêu cầu Liên hệ</h3>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left"></i> Quay lại</a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Nội dung yêu cầu</h6>
            </div>
            <div class="card-body">
                <h5 class="fw-bold mb-3">@Model.Subject</h5>
                <div class="p-3 bg-light rounded" style="white-space: pre-wrap; font-size: 0.95rem;">@Model.Message</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Thông tin Người gửi</h6>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <span class="text-muted">Họ và tên:</span>
                        <span class="fw-bold">@Model.Name</span>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <span class="text-muted">Email:</span>
                        <span><a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a></span>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <span class="text-muted">Ngày gửi:</span>
                        <span>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <span class="text-muted">Trạng thái:</span>
                        <span class="badge bg-success">Đã đọc</span>
                    </li>
                </ul>

                <hr class="my-3" />
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa thư này?');">
                    <button type="submit" class="btn btn-outline-danger w-100"><i class="fas fa-trash me-2"></i>Xóa yêu cầu này</button>
                </form>
            </div>
        </div>
    </div>
</div>
