@model IEnumerable<AdmissionWeb.Models.Entities.ApplicationUser>
@{
    ViewData["Title"] = "Quản lý Tài khoản";
}

<h3 class="mb-4"><i class="fas fa-users text-primary me-2"></i>Quản lý Tài khoản</h3>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="mb-0 fw-bold">Danh sách người dùng</h6>
        <a asp-action="Create" class="btn btn-primary-sharp btn-sm"><i class="fas fa-plus me-1"></i> Thêm tài khoản</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Họ và tên</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Ngày tạo</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@user.FullName</strong></td>
                            <td>@user.Email</td>
                            <td>@(user.PhoneNumber ?? "—")</td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if(user.EmailConfirmed) {
                                    <span class="badge bg-success">Đã xác thực</span>
                                } else {
                                    <span class="badge bg-warning text-dark">Chưa xác thực</span>
                                }
                                @if(user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow) {
                                    <span class="badge bg-danger ms-1">Đã khóa</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                                <form asp-action="ToggleLock" asp-route-id="@user.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn thay đổi trạng thái khóa tài khoản này?');">
                                    <button type="submit" class="btn btn-sm @(user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow ? "btn-warning" : "btn-outline-danger")" title="@(user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow ? "Mở khóa" : "Khóa")">
                                        <i class="fas @(user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow ? "fa-unlock" : "fa-lock")"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
