@model IEnumerable<AdmissionWeb.Models.Entities.Banner>

@{
    ViewData["Title"] = "Quản lý Banner";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 fw-bold text-primary"><i class="fas fa-images me-2"></i> @ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="fas fa-plus me-2"></i>Thêm Banner Mới
    </a>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Hình ảnh</th>
                        <th>Tiêu đề</th>
                        <th>Thứ tự</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Title" class="img-thumbnail" style="height: 60px; object-fit: cover; border-radius: 8px;" />
                                }
                                else
                                {
                                    <div class="bg-light text-muted d-flex align-items-center justify-content-center rounded" style="width: 100px; height: 60px;">
                                        <i class="fas fa-image fs-4"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold">@item.Title</td>
                            <td><span class="badge bg-secondary rounded-pill px-3">@item.DisplayOrder</span></td>
                            <td>
                                <div class="form-check form-switch">
                                    <input class="form-check-input toggle-status" type="checkbox" role="switch" id="switch_@item.Id" data-id="@item.Id" @(item.IsActive ? "checked" : "")>
                                    <label class="form-check-label" for="switch_@item.Id">@(item.IsActive ? "Hiển thị" : "Đã ẩn")</label>
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill me-2">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa banner này?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-images fs-1 mb-3 text-light"></i>
                                <p class="mb-0">Chưa có banner nào. Hãy thêm banner mới!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.toggle-status').change(function () {
                var isChecked = $(this).is(':checked');
                var label = $(this).next('label');
                var id = $(this).data('id');

                $.post('@Url.Action("ToggleStatus")', { id: id }, function (res) {
                    if (res.success) {
                        label.text(res.isActive ? "Hiển thị" : "Đã ẩn");
                    } else {
                        alert("Có lỗi xảy ra khi cập nhật trạng thái!");
                    }
                });
            });
        });
    </script>
}
