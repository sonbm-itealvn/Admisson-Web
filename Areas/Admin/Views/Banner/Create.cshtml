@model AdmissionWeb.Models.Entities.Banner

@{
    ViewData["Title"] = "Thêm Banner Mới";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 fw-bold text-primary"><i class="fas fa-plus-circle me-2"></i> @ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
        <i class="fas fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-4">
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold">Tiêu đề Banner <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề banner" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Hình ảnh Banner <span class="text-danger">*</span></label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" required />
                        <div class="form-text">Chọn hình ảnh định dạng JPG, PNG. Đề xuất tỷ lệ 16:9 hoặc 21:9.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LinkUrl" class="form-label fw-bold">Đường dẫn khi click (tùy chọn)</label>
                        <input asp-for="LinkUrl" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="LinkUrl" class="text-danger"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="DisplayOrder" class="form-label fw-bold">Thứ tự hiển thị</label>
                            <input asp-for="DisplayOrder" class="form-control" type="number" />
                            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch fs-5 mb-1">
                                <input class="form-check-input" asp-for="IsActive" />
                                <label class="form-check-label ms-2" asp-for="IsActive">Kích hoạt hiển thị</label>
                            </div>
                        </div>
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm">
                            <i class="fas fa-save me-2"></i>Lưu Banner
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
