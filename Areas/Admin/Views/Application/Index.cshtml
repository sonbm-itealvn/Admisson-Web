@model IEnumerable<AdmissionWeb.Models.Entities.Application>
@{
    ViewData["Title"] = "Quản lý hồ sơ tuyển sinh";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Danh sách hồ sơ đăng ký</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-file-export"></i> Xuất Excel
        </button>
    </div>
</div>

<div class="table-responsive shadow-sm bg-white p-3 rounded">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Mã hồ sơ</th>
                <th>Họ tên</th>
                <th>Ngày sinh</th>
                <th>CCCD</th>
                <th>Kỳ tuyển sinh</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var app in Model)
            {
                <tr>
                    <td><strong>@app.ApplicationCode</strong></td>
                    <td>@app.FullName</td>
                    <td>@app.DateOfBirth.ToString("dd/MM/yyyy")</td>
                    <td>@app.IDNumber</td>
                    <td class="small">@app.AdmissionPeriod.Name</td>
                    <td>
                        @switch (app.Status)
                        {
                            case "Pending":
                                @:<span class="badge bg-warning text-dark">Chờ duyệt</span>
                                break;
                            case "Approved":
                                @:<span class="badge bg-success">Đã duyệt</span>
                                break;
                            case "Rejected":
                                @:<span class="badge bg-danger">Từ chối</span>
                                break;
                            default:
                                @:<span class="badge bg-secondary">@app.Status</span>
                                break;
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@app.Id" class="btn btn-sm btn-info text-white">
                            <i class="fas fa-eye"></i> Chi tiết
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
