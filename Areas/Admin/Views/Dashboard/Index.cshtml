@model IEnumerable<AdmissionWeb.Models.Entities.Application>
@{
    ViewData["Title"] = "Dashboard";
}

<h3 class="mb-4"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</h3>

<!-- Stat Cards -->
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-primary shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="me-3">
                    <i class="fas fa-file-alt fa-2x"></i>
                </div>
                <div>
                    <h3 class="card-title mb-0">@ViewBag.TotalApplications</h3>
                    <small>Tổng hồ sơ</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-dark bg-warning shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="me-3">
                    <i class="fas fa-clock fa-2x"></i>
                </div>
                <div>
                    <h3 class="card-title mb-0">@ViewBag.PendingCount</h3>
                    <small>Chờ duyệt</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-success shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="me-3">
                    <i class="fas fa-check-circle fa-2x"></i>
                </div>
                <div>
                    <h3 class="card-title mb-0">@ViewBag.ApprovedCount</h3>
                    <small>Đã duyệt</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-danger shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="me-3">
                    <i class="fas fa-times-circle fa-2x"></i>
                </div>
                <div>
                    <h3 class="card-title mb-0">@ViewBag.RejectedCount</h3>
                    <small>Từ chối</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Applications Table -->
<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="fas fa-list me-2"></i>Hồ sơ gần đây</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã hồ sơ</th>
                        <th>Họ và tên</th>
                        <th>Ngày nộp</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.ApplicationCode</strong></td>
                            <td>@item.FullName</td>
                            <td>@item.SubmittedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                @switch (item.Status)
                                {
                                    case "Pending":
                                        @:<span class="badge bg-warning text-dark">Chờ duyệt</span>
                                        break;
                                    case "Approved":
                                        @:<span class="badge bg-success">Đã duyệt</span>
                                        break;
                                    case "Rejected":
                                        @:<span class="badge bg-danger">Từ chối</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a asp-area="Admin" asp-controller="Application" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye me-1"></i>Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
