@model IEnumerable<AdmissionWeb.Models.Entities.NewsArticle>
@{
    ViewData["Title"] = "Tin tức & Thông báo";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold section-title d-inline-block">TIN TỨC & THÔNG BÁO</h2>
        <p class="text-muted mt-2">Cập nhật những thông tin mới nhất từ Trường THPT Kiến Trúc</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 news-card" style="transition: transform 0.3s ease, box-shadow 0.3s ease;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center text-muted" style="height: 200px;">
                                <i class="fas fa-image fa-3x"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="mb-2">
                                <span class="badge bg-primary-sharp px-2 py-1 small">@item.Category</span>
                                <small class="text-muted ms-2"><i class="fas fa-calendar-alt me-1"></i> @item.PublishedAt.ToString("dd/MM/yyyy")</small>
                            </div>
                            <h5 class="card-title fw-bold mt-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none hover-primary">
                                    @item.Title
                                </a>
                            </h5>
                            <p class="card-text text-muted" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @Html.Raw(System.Text.RegularExpressions.Regex.Replace(item.Content ?? "", "<.*?>", String.Empty))
                            </p>
                            <div class="mt-auto pt-3 border-top">
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-primary fw-bold text-decoration-none">
                                    Đọc tiếp <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-newspaper fa-4x text-muted mb-3"></i>
                <h5 class="text-muted">Chưa có bài viết nào được xuất bản.</h5>
            </div>
        }
    </div>
</div>

<style>
    .news-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>
