@model AdmissionWeb.Models.Entities.NewsArticle
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <div class="row">
        <!-- Main Content Area -->
        <div class="col-lg-9 col-md-12 bg-white p-3 p-md-4 hau-news-container">
            
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb m-0 p-0" style="background: transparent; font-size: 14px;">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none" style="color: #333;">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none" style="color: #333;">Tin tức</a></li>
                    <li class="breadcrumb-item active" aria-current="page" style="color: #02519A;">@Model.Title</li>
                </ol>
            </nav>

            <article class="hau-article">
                <!-- Title -->
                <h1 class="hau-article-title">@Model.Title</h1>
                
                <!-- Date -->
                <div class="hau-article-date">
                    (Ngày đăng: @Model.PublishedAt.ToString("dd/MM/yyyy HH:mm"))
                </div>
                
                <!-- Social Share (Optional, often placed under date in traditional sites) -->
                <div class="hau-share-buttons mb-4">
                    <a href="javascript:void(0)" class="hau-btn-share"><i class="fab fa-facebook-f"></i> Thích</a>
                    <a href="javascript:void(0)" class="hau-btn-share"><i class="fas fa-share-alt"></i> Chia sẻ</a>
                </div>

                <!-- Content -->
                <div class="hau-article-content">
                    @Html.Raw(Model.Content)
                </div>

                <!-- Author info if exists -->
                @if (!string.IsNullOrEmpty(Model.Author))
                {
                    <div class="text-end mt-4 fw-bold" style="font-size: 15px; color: #333;">
                        @Model.Author
                    </div>
                }

                <!-- Footer & Sharing -->
                <div class="mt-5 pt-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-undo-alt"></i> Quay lại
                    </a>
                </div>
            </article>

        </div>
        
        <!-- Right Sidebar (Latest News) -->
        <div class="col-lg-3 mt-4 mt-lg-0">
            <div class="p-3 bg-light border" style="min-height: 400px;">
                <h4 class="fw-bold mb-3" style="color: #02519A; font-size: 16px; border-bottom: 2px solid #02519A; padding-bottom: 8px;">TIN TỨC MỚI NHẤT</h4>
                <!-- Placeholder for related news -->
                <ul class="list-unstyled hau-related-list">
                    @if (ViewBag.LatestNews != null)
                    {
                        foreach (var item in (IEnumerable<AdmissionWeb.Models.Entities.NewsArticle>)ViewBag.LatestNews)
                        {
                            <li class="mb-2">
                                <a asp-controller="News" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none" style="color: #333; font-size: 14px;">
                                    <i class="fas fa-caret-right me-2" style="color: #02519A;"></i>@item.Title
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            function getTextNodes(node) {
                var textNodes = [];
                if (node.nodeType === 3) {
                    var text = node.nodeValue.trim();
                    if (text.length > 0) {
                        textNodes.push(node);
                    }
                } else {
                    var children = node.childNodes;
                    for (var i = 0; i < children.length; i++) {
                        textNodes.push.apply(textNodes, getTextNodes(children[i]));
                    }
                }
                return textNodes;
            }

            var contentNode = $('.hau-article-content')[0];
            if (!contentNode) return;

            var textNodes = getTextNodes(contentNode);
            var urlRegex = /(https?:\/\/[^\s]+)/g;
            var processed = false;

            for (var i = textNodes.length - 1; i >= 0; i--) {
                var node = textNodes[i];
                var $closestA = $(node).closest('a');
                
                if ($closestA.length > 0) {
                    if (!processed) {
                        $closestA.addClass('hau-action-btn');
                        $closestA.attr('target', '_blank');
                        $closestA.html('Xem chi tiết <i class="fas fa-angle-double-right ms-1"></i>');
                        
                        var $parentP = $closestA.closest('p, div');
                        if ($parentP.length > 0 && $parentP[0] !== contentNode) {
                            $parentP.addClass('text-center mt-4 mb-4');
                        } else {
                            $closestA.wrap('<div class="text-center mt-4 mb-4"></div>');
                        }
                        processed = true;
                    }
                    continue; 
                }

                var text = node.nodeValue;
                var match = text.match(urlRegex);
                if (match && !processed) {
                    var lastUrl = match[match.length - 1];
                    var newHtml = text.replace(lastUrl, '<a href="' + lastUrl + '" target="_blank" class="hau-action-btn">Xem chi tiết <i class="fas fa-angle-double-right ms-1"></i></a>');
                    
                    var $wrapper = $('<span>').html(newHtml);
                    $(node).replaceWith($wrapper);

                    var $parentP = $wrapper.closest('p, div');
                    if ($parentP.length > 0 && $parentP[0] !== contentNode) {
                        $parentP.addClass('text-center mt-4 mb-4');
                    } else {
                        $wrapper.wrap('<div class="text-center mt-4 mb-4"></div>');
                    }
                    
                    processed = true;
                }
                
                if (processed) break;
            }
        });
    </script>
}

<style>
    .hau-news-container {
        border-right: 1px solid #ddd;
    }
    @@media (max-width: 991.98px) {
        .hau-news-container {
            border-right: none;
        }
    }

    .hau-article {
        font-family: Arial, Helvetica, sans-serif;
    }
    
    .hau-article-title {
        font-size: 24px;
        font-weight: bold;
        color: #02519A;
        line-height: 1.4;
        margin-top: 15px;
        margin-bottom: 5px;
    }
    
    .hau-article-date {
        font-size: 13px;
        font-style: italic;
        color: #666;
        margin-bottom: 10px;
    }

    .hau-btn-share {
        display: inline-block;
        background-color: #1877f2;
        color: white;
        font-size: 11px;
        font-weight: bold;
        padding: 2px 8px;
        border-radius: 3px;
        text-decoration: none;
        margin-right: 5px;
    }
    .hau-btn-share:hover {
        color: white;
        opacity: 0.9;
    }

    .hau-article-content {
        font-size: 15px;
        line-height: 1.6;
        color: #333;
        text-align: justify;
    }
    .hau-article-content p {
        margin-bottom: 15px;
        text-align: justify;
    }
    .hau-article-content img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 15px auto;
    }
    .hau-article-content table {
        width: 100% !important;
    }

    .hau-action-btn {
        display: inline-block;
        background-color: #02519A;
        color: #fff !important;
        font-size: 14px;
        font-weight: bold;
        padding: 8px 20px;
        text-decoration: none;
        border-radius: 4px;
        transition: background-color 0.2s;
    }
    .hau-action-btn:hover {
        background-color: #F57E20;
    }

    .hau-related-list a:hover {
        color: #02519A !important;
        text-decoration: underline !important;
    }
</style>
