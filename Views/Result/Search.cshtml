@model AdmissionWeb.Models.ViewModels.ResultSearchViewModel
@{
    ViewData["Title"] = "Tra cứu kết quả tuyển sinh";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center py-4">
                    <h2 class="mb-0">Tra Cứu Kết Quả Tuyển Sinh</h2>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Search" method="post" class="mb-5">
                        <div class="input-group input-group-lg">
                            <input type="text" name="searchTerm" class="form-control" placeholder="Nhập Mã hồ sơ hoặc Số CCCD..." value="@Model.SearchTerm" required>
                            <button class="btn btn-primary px-4" type="submit"><i class="fas fa-search"></i> Tra cứu</button>
                        </div>
                        <div class="form-text mt-2 text-center">Hệ thống sẽ hiển thị trạng thái hồ sơ và điểm thi (nếu có).</div>
                    </form>

                    @if (Model.IsSearched)
                    {
                        if (Model.Application != null)
                        {
                            <div class="result-box p-4 bg-light rounded border">
                                <h4 class="text-center text-primary mb-4">Thông Tin Kết Quả</h4>
                                <div class="row mb-3">
                                    <div class="col-sm-4 fw-bold">Họ và tên:</div>
                                    <div class="col-sm-8 text-uppercase">@Model.Application.FullName</div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-sm-4 fw-bold">Mã hồ sơ:</div>
                                    <div class="col-sm-8">@Model.Application.ApplicationCode</div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-sm-4 fw-bold">Trạng thái hồ sơ:</div>
                                    <div class="col-sm-8">
                                    @switch (Model.Application.Status)
                                    {
                                        case "Pending":
                                            @:<span class="badge bg-warning text-dark">Đang chờ duyệt</span>
                                            break;
                                        case "Approved":
                                            @:<span class="badge bg-success">Đã duyệt hồ sơ</span>
                                            break;
                                        case "Rejected":
                                            @:<span class="badge bg-danger">Từ chối hồ sơ</span>
                                            break;
                                        default:
                                            @:<span class="badge bg-secondary">@Model.Application.Status</span>
                                            break;
                                    }
                                    </div>
                                </div>

                                @if (Model.Application.ExamResults != null && Model.Application.ExamResults.Any())
                                {
                                    <div class="mt-4">
                                        <h5 class="border-bottom pb-2">Điểm thi các môn:</h5>
                                        <table class="table table-bordered bg-white">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Môn thi</th>
                                                    <th class="text-center">Điểm số</th>
                                                    <th>Ghi chú</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var res in Model.Application.ExamResults)
                                                {
                                                    <tr>
                                                        <td>@res.SubjectName</td>
                                                        <td class="text-center fw-bold text-danger">@res.Score</td>
                                                        <td>@res.Remarks</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else if (Model.Application.Status == "Approved")
                                {
                                    <div class="alert alert-info mt-4">
                                        <i class="fas fa-info-circle"></i> Hồ sơ đã được duyệt, điểm thi sẽ được cập nhật sau khi có kết quả chính thức.
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-danger text-center">
                                <i class="fas fa-exclamation-triangle"></i> Không tìm thấy hồ sơ nào khớp với thông tin bạn cung cấp. Vui lòng kiểm tra lại.
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
