<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Trường THPT Kiến Trúc</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="geometric-bg">


    <header>
        <div class="header-main p-0" style="background-color: #005bb5; border-bottom: 3px solid #f37021; overflow: hidden;">
            <div class="container p-0">
                <div class="d-flex align-items-stretch" style="position: relative; min-height: 90px; z-index: 1;">
                    
                    <!-- Slanted Backgrounds for Desktop -->
                    <div class="d-none d-lg-block" style="position: absolute; top: 0; bottom: 0; left: -2000px; width: calc(2000px + 160px); background-color: white; z-index: 1;">
                        <div style="position: absolute; top: 0; bottom: 0; right: -20px; width: 50px; background-color: white; transform: skewX(-25deg);"></div>
                    </div>
                    <div class="d-none d-lg-block" style="position: absolute; top: 0; bottom: 0; left: 185px; width: 12px; background-color: #58b947; transform: skewX(-25deg); z-index: 1;"></div>
                    <div class="d-none d-lg-block" style="position: absolute; top: 0; bottom: 0; left: 202px; width: 12px; background-color: #f37021; transform: skewX(-25deg); z-index: 1;"></div>

                    <!-- Content -->
                    <div class="d-flex align-items-center w-100" style="position: relative; z-index: 2;">
                        
                        <!-- Logo -->
                        <div class="d-flex align-items-center justify-content-center px-2" style="width: 160px; background-color: white; height: 100%;">
                            <a href="/">
                                <img src="/images/logo.png" alt="Logo" style="max-height: 70px;" onerror="this.outerHTML='<h6 class=\'text-primary fw-bold mb-0\'>THPT KIẾN TRÚC</h6>'" />
                            </a>
                        </div>
                        
                        <!-- Text -->
                        <div class="flex-grow-1 ps-lg-5 ps-3 py-2 d-none d-md-flex flex-column justify-content-center text-white" style="margin-left: 60px;">
                            <div style="font-family: 'Times New Roman', Times, serif; font-size: 1.25rem; margin-bottom: -2px;">
                                Sở Giáo dục và Đào tạo Hà Nội &nbsp;&nbsp;&nbsp;&nbsp; Trường Đại học Kiến trúc Hà Nội
                            </div>
                            <div style="font-family: Arial, Helvetica, sans-serif; font-size: 1.7rem; font-weight: bold; letter-spacing: 0px;">
                                TRƯỜNG TRUNG HỌC PHỔ THÔNG KIẾN TRÚC
                            </div>
                        </div>
                        <div class="flex-grow-1 ps-3 py-2 d-md-none text-white">
                            <h5 class="fw-bold mb-0">THPT KIẾN TRÚC</h5>
                        </div>

                    </div>
                </div>
            </div>
        </div>
        
        <div class="header-bottom shadow-sm">
            <div class="container">
                <nav class="navbar navbar-expand-lg navbar-dark p-0">
                    <button class="navbar-toggler my-2 ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainMenu">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i> TRANG CHỦ</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">GIỚI THIỆU</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Admission" asp-action="Index">THÔNG TIN TUYỂN SINH</a></li>
                            <li class="nav-item d-none"><a class="nav-link" asp-area="" asp-controller="Application" asp-action="Register">ĐĂNG KÝ HỒ SƠ</a></li>
                            <li class="nav-item d-none"><a class="nav-link" asp-area="" asp-controller="Result" asp-action="Search">TRA CỨU KẾT QUẢ</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="News" asp-action="Index">TIN TỨC</a></li>
                            <li class="nav-item d-lg-none mt-2 border-top pt-2">
                                <partial name="_LoginPartial" />
                            </li>
                        </ul>
                        <div class="d-none d-lg-block login-nav-block">
                            <partial name="_LoginPartial" />
                        </div>
                    </div>
                </nav>
            </div>
        </div>
        <style>
            @@media (min-width: 992px) {
                .login-nav-block .nav-link,
                .login-nav-block .text-dark {
                    color: rgba(255, 255, 255, 0.9) !important;
                }
                .login-nav-block .text-muted {
                    color: rgba(255, 255, 255, 0.5) !important;
                }
            }
        </style>
    </header>

    <div class="container mt-4 mb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 border-top border-bottom border-dark" style="background-color: #02519A; border-width: 2px !important; overflow: hidden; padding: 0;">
        <div class="mx-auto" style="max-width: 1400px; display: block; overflow: hidden;">
            <img src="/images/footer.png" alt="Footer" style="width: 100%; height: auto; display: block;" onerror="this.outerHTML='<div class=\'text-white text-center p-4\'>Vui lòng tải ảnh footer của bạn vào thư mục <strong>wwwroot/images/footer.png</strong> để hiển thị.</div>'" />
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
