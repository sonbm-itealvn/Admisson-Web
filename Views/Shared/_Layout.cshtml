<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Trường THPT Kiến Trúc</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="geometric-bg">


    <header>
        <div class="header-main p-0" style="background-color: #005bb5; border-bottom: 3px solid #f37021; overflow: hidden;">
            <div class="container p-0">
                <div class="d-flex align-items-stretch" style="position: relative; min-height: 90px; z-index: 1;">
                    
                    <!-- Slanted Backgrounds for Desktop -->
                    <div class="d-none d-lg-block" style="position: absolute; top: 0; bottom: 0; left: -2000px; width: calc(2000px + 160px); background-color: white; z-index: 1;">
                        <div style="position: absolute; top: 0; bottom: 0; right: -20px; width: 50px; background-color: white; transform: skewX(-25deg);"></div>
                    </div>
                    <div class="d-none d-lg-block" style="position: absolute; top: 0; bottom: 0; left: 185px; width: 12px; background-color: #58b947; transform: skewX(-25deg); z-index: 1;"></div>
                    <div class="d-none d-lg-block" style="position: absolute; top: 0; bottom: 0; left: 202px; width: 12px; background-color: #f37021; transform: skewX(-25deg); z-index: 1;"></div>

                        <!-- Text -->
                        <style>
                            .header-logo-container {
                                width: 160px;
                                background-color: white;
                                height: 100%;
                            }
                            .header-logo-img {
                                max-height: 70px;
                            }
                            .header-text-container {
                                margin-left: 10px;
                                padding-right: 10px;
                            }
                            .header-sub {
                                font-family: 'Times New Roman', Times, serif; 
                                font-size: 0.65rem; 
                                margin-bottom: 2px;
                                line-height: 1.3;
                            }
                            .header-main-title {
                                font-family: Arial, Helvetica, sans-serif; 
                                font-size: 0.85rem; 
                                font-weight: bold; 
                                letter-spacing: 0px;
                                line-height: 1.3;
                            }
                            @@media (min-width: 768px) {
                                .header-text-container {
                                    margin-left: 40px;
                                }
                                .header-sub {
                                    font-size: 1rem;
                                }
                                .header-main-title {
                                    font-size: 1.3rem;
                                }
                            }
                            @@media (min-width: 992px) {
                                .header-text-container {
                                    margin-left: 60px;
                                }
                                .header-sub {
                                    font-size: 1.25rem;
                                    margin-bottom: -2px;
                                }
                                .header-main-title {
                                    font-size: 1.7rem;
                                }
                            }
                            @@media (max-width: 576px) {
                                .header-logo-container {
                                    width: 90px !important;
                                    padding: 5px !important;
                                }
                                .header-logo-img {
                                    max-height: 45px !important;
                                }
                                .header-text-container {
                                    margin-left: 5px !important;
                                }
                                .header-sub {
                                    font-size: 0.55rem;
                                }
                                .header-main-title {
                                    font-size: 0.75rem;
                                }
                            }
                        </style>
                        <div class="d-flex align-items-center w-100" style="position: relative; z-index: 2;">
                            
                            <!-- Logo -->
                            <div class="d-flex align-items-center justify-content-center px-2 header-logo-container">
                                <a href="/">
                                    <img src="/images/logo.png" alt="Logo" class="header-logo-img" onerror="this.outerHTML='<h6 class=\'text-primary fw-bold mb-0\'>KT</h6>'" />
                                </a>
                            </div>
                            
                            <!-- Text -->
                            <div class="flex-grow-1 ps-lg-5 ps-2 py-2 d-flex flex-column justify-content-center text-white header-text-container">
                                <div class="header-sub">
                                    Sở Giáo dục và Đào tạo Hà Nội &nbsp;&nbsp; Trường Đại học Kiến trúc Hà Nội
                                </div>
                                <div class="header-main-title">
                                    TRƯỜNG TRUNG HỌC PHỔ THÔNG <span style="white-space: nowrap;">KIẾN TRÚC</span>
                                </div>
                            </div>

                            <!-- Mobile Menu Toggle (Moved up) -->
                            <div class="d-lg-none d-flex align-items-center pe-3">
                                <button class="btn text-white" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu" aria-expanded="false" style="border: 1px solid rgba(255,255,255,0.4); padding: 4px 10px; border-radius: 4px;">
                                    <i class="fas fa-bars" style="font-size: 1.4rem;"></i>
                                </button>
                            </div>

                        </div>
                </div>
            </div>
        </div>
        
        <div class="header-bottom header-bottom-mobile-fix">
            <div class="container px-0 px-lg-2">
                <nav class="navbar navbar-expand-lg navbar-dark p-0">
                    <div class="collapse navbar-collapse" id="mainMenu">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i> TRANG CHỦ</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">GIỚI THIỆU</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Admission" asp-action="Index">THÔNG TIN TUYỂN SINH</a></li>
                            <li class="nav-item d-none"><a class="nav-link" asp-area="" asp-controller="Application" asp-action="Register">ĐĂNG KÝ HỒ SƠ</a></li>
                            <li class="nav-item d-none"><a class="nav-link" asp-area="" asp-controller="Result" asp-action="Search">TRA CỨU KẾT QUẢ</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="News" asp-action="Index">TIN TỨC</a></li>
                            <li class="nav-item d-lg-none mt-2 border-top pt-2 px-3 pb-3">
                                <partial name="_LoginPartial" />
                            </li>
                        </ul>
                        <div class="d-none d-lg-block login-nav-block">
                            <partial name="_LoginPartial" />
                        </div>
                    </div>
                </nav>
            </div>
        </div>
        <style>
            @@media (max-width: 991.98px) {
                .header-bottom-mobile-fix {
                    position: absolute;
                    width: 100%;
                    z-index: 1050;
                    background-color: #005bb5;
                    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
                }
            }
            @@media (min-width: 992px) {
                .login-nav-block .nav-link,
                .login-nav-block .text-dark {
                    color: rgba(255, 255, 255, 0.9) !important;
                }
                .login-nav-block .text-muted {
                    color: rgba(255, 255, 255, 0.5) !important;
                }
            }
        </style>
    </header>

    <div class="container mt-4 mb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 border-top border-bottom border-dark" style="background-color: #02519A; border-width: 2px !important; overflow: hidden; padding: 0;">
        <div class="mx-auto" style="max-width: 1400px; display: block; overflow: hidden;">
            <img src="/images/footer.png" alt="Footer" style="width: 100%; height: auto; display: block;" onerror="this.outerHTML='<div class=\'text-white text-center p-4\'>Vui lòng tải ảnh footer của bạn vào thư mục <strong>wwwroot/images/footer.png</strong> để hiển thị.</div>'" />
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
