<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Trường THPT Kiến Trúc</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="geometric-bg">
    <!-- Top Bar -->
    <div class="top-bar py-2 d-none d-lg-block">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex">
                <a asp-controller="Application" asp-action="Register" class="d-none">Đăng ký hồ sơ</a>
                <a asp-controller="Result" asp-action="Search" class="d-none">Tra cứu kết quả</a>
                <a href="#">Tải biểu mẫu</a>
                <a href="#">FAQ</a>
                <a asp-controller="Contact" asp-action="Index">Liên hệ</a>
            </div>
            <div class="social-icons">
                <a href="#" class="fb"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="yt"><i class="fab fa-youtube"></i></a>
                <a href="#" class="tt"><i class="fab fa-tiktok"></i></a>
            </div>
        </div>
    </div>

    <!-- Header NTTHNUE Style -->
    <header>
        <div class="header-main">
            <div class="container d-flex align-items-center justify-content-between py-2">
                <div class="d-flex align-items-center">
                    <a href="/" class="text-decoration-none d-flex align-items-center">
                        <img src="/images/logo.png" alt="Logo" onerror="this.outerHTML='<div class=\'logo-box me-3\'><i class=\'fas fa-city\'></i></div>'" style="max-height: 70px; margin-right: 15px;" />
                        <div>
                            <p class="header-sub-text">SỞ GIÁO DỤC VÀ ĐÀO TẠO</p>
                            <h2 class="header-brand-text">TRƯỜNG THPT KIẾN TRÚC</h2>
                        </div>
                    </a>
                </div>
                
                <div class="d-none d-lg-block">
                    <partial name="_LoginPartial" />
                </div>
                <button class="navbar-toggler d-lg-none border-0 fs-2 text-primary" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
        </div>
        
        <div class="header-bottom shadow-sm">
            <div class="container">
                <nav class="navbar navbar-expand-lg navbar-dark p-0">
                    <div class="collapse navbar-collapse" id="mainMenu">
                        <ul class="navbar-nav w-100">
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i> TRANG CHỦ</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">GIỚI THIỆU</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Admission" asp-action="Index">THÔNG TIN TUYỂN SINH</a></li>
                            <li class="nav-item d-none"><a class="nav-link" asp-area="" asp-controller="Application" asp-action="Register">ĐĂNG KÝ HỒ SƠ</a></li>
                            <li class="nav-item d-none"><a class="nav-link" asp-area="" asp-controller="Result" asp-action="Search">TRA CỨU KẾT QUẢ</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="News" asp-action="Index">TIN TỨC</a></li>
                            <li class="nav-item d-lg-none mt-2 border-top pt-2">
                                <partial name="_LoginPartial" />
                            </li>
                        </ul>
                    </div>
                </nav>
            </div>
        </div>
    </header>

    <div class="bg-warning text-dark py-2 text-center shadow-sm">
        <marquee behavior="scroll" direction="left" scrollamount="6" class="fw-bold mb-0" style="font-size: 1.1rem;">
            <i class="fas fa-tools me-2"></i> Website đang trong quá trình phát triển và cập nhật
        </marquee>
    </div>

    <div class="container mt-4 mb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 border-top border-bottom border-dark" style="background-color: #02519A; border-width: 2px !important; overflow: hidden; padding: 0;">
        <div class="mx-auto" style="max-width: 1400px; display: block; overflow: hidden;">
            <img src="/images/footer.png" alt="Footer" style="width: 100%; height: auto; display: block;" onerror="this.outerHTML='<div class=\'text-white text-center p-4\'>Vui lòng tải ảnh footer của bạn vào thư mục <strong>wwwroot/images/footer.png</strong> để hiển thị.</div>'" />
        </div>
    </footer>

    <!-- Floating Action Button -->
    <a asp-controller="Application" asp-action="Register" class="btn btn-primary rounded-pill shadow-lg floating-btn">
        <i class="fas fa-paper-plane me-2"></i>Nộp hồ sơ
    </a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <style>
        .floating-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 1000;
            padding: 15px 25px;
            font-size: 1.1rem;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.4) !important;
            transition: all 0.3s ease;
        }
        .floating-btn:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 6px 20px rgba(13, 110, 253, 0.6) !important;
        }
    </style>
</body>
</html>
