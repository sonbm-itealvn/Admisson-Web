@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var initials = string.IsNullOrEmpty(user?.FullName) 
        ? user?.Email?.Substring(0, 1).ToUpper() ?? "U"
        : string.Join("", user.FullName.Split(' ').Where(w => w.Length > 0).Select(w => w[0])).Substring(0, Math.Min(2, user.FullName.Split(' ').Length)).ToUpper();

    <li class="nav-item dropdown user-dropdown">
        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <div class="user-avatar bg-primary text-white d-flex align-items-center justify-content-center rounded-circle me-2 fw-bold" style="width: 35px; height: 35px; font-size: 0.9rem;">
                @initials
            </div>
            <span class="d-none d-lg-inline fw-bold text-dark" style="font-size: 0.85rem;">
                @(user?.FullName ?? user?.Email)
            </span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">
            @if (User.IsInRole("Admin") || User.IsInRole("AdmissionOfficer"))
            {
                <li>
                    <a class="dropdown-item py-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-cogs text-primary me-2 w-15px text-center"></i> Quản trị hệ thống
                    </a>
                </li>
            }
            <li>
                <a class="dropdown-item py-2" asp-area="" asp-controller="Application" asp-action="MyApplications">
                    <i class="fas fa-folder-open text-warning me-2 w-15px text-center"></i> Hồ sơ của tôi
                </a>
            </li>
            <li>
                <a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                    <i class="fas fa-user-circle text-info me-2 w-15px text-center"></i> Tài khoản của tôi
                </a>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="dropdown-item py-2 text-danger">
                        <i class="fas fa-sign-out-alt me-2 w-15px text-center"></i> Đăng xuất
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark fw-bold text-uppercase d-flex align-items-center transition-hover text-nowrap" style="font-size: 0.85rem;" asp-area="Identity" asp-page="/Account/Login">
            <i class="fas fa-sign-in-alt me-1 text-primary"></i> Đăng nhập
        </a>
    </li>
    <li class="nav-item d-none d-lg-flex align-items-center px-1">
        <span class="text-muted" style="font-size: 1.2rem; opacity: 0.3;">|</span>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark fw-bold text-uppercase d-flex align-items-center transition-hover text-nowrap" style="font-size: 0.85rem;" asp-area="Identity" asp-page="/Account/Register">
            <i class="fas fa-user-plus me-1 text-primary"></i> Đăng ký
        </a>
    </li>
}
</ul>
