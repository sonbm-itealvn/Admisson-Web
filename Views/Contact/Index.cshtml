@model AdmissionWeb.Models.Entities.ContactRequest
@{
    ViewData["Title"] = "Liên hệ";
}

<div class="row mt-4 mb-5">
    <div class="col-12 text-center mb-5">
        <h2 class="section-title mb-3">LIÊN HỆ VỚI CHÚNG TÔI</h2>
        <p class="text-muted">Chúng tôi luôn sẵn sàng lắng nghe và giải đáp mọi thắc mắc của bạn.</p>
    </div>

    <div class="col-md-5 mb-4">
        <div class="card border-0 shadow-sm h-100" style="border-top: 4px solid var(--primary-blue) !important;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">THÔNG TIN LIÊN HỆ</h5>
                
                <div class="d-flex align-items-start mb-4">
                    <div class="icon-hexagon me-3" style="width: 40px; height: 40px; min-width: 40px;">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Địa chỉ</h6>
                        <p class="text-muted mb-0">Trường THPT Kiến Trúc<br/>Số 129 đường Trần Phú, Phường Hà Đông, TP. Hà Nội</p>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-4">
                    <div class="icon-hexagon me-3" style="width: 40px; height: 40px; min-width: 40px;">
                        <i class="fas fa-phone-alt"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Điện thoại</h6>
                        <p class="text-muted mb-0">(090) 200 2529<br/>Hotline: 0961 901 575</p>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-4">
                    <div class="icon-hexagon me-3" style="width: 40px; height: 40px; min-width: 40px;">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Email</h6>
                        <p class="text-muted mb-0">thptkientruc.hau.edu.vn<br/>thpt.hau.edu.vn</p>
                    </div>
                </div>

                <hr class="my-4">
                <h6 class="fw-bold mb-3">KẾT NỐI VỚI CHÚNG TÔI</h6>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-primary" style="background-color: #3b5998; border: none;"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="btn btn-danger" style="background-color: #cd201f; border: none;"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-7 mb-4">
        <div class="card border border-primary shadow-sm h-100">
            <div class="card-body p-4 p-md-5">
                <h5 class="fw-bold mb-4">GỬI YÊU CẦU CHO CHÚNG TÔI</h5>
                
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Submit" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control bg-light" required placeholder="Nhập họ và tên..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email liên hệ <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control bg-light" required placeholder="Nhập email..." />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label fw-bold">Tiêu đề <span class="text-danger">*</span></label>
                        <input asp-for="Subject" class="form-control bg-light" required placeholder="Nhập tiêu đề cần hỏi..." />
                        <span asp-validation-for="Subject" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Message" class="form-label fw-bold">Nội dung chi tiết <span class="text-danger">*</span></label>
                        <textarea asp-for="Message" class="form-control bg-light" rows="5" required placeholder="Viết nội dung chi tiết..."></textarea>
                        <span asp-validation-for="Message" class="text-danger small"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-primary-sharp w-100 py-3">
                        <i class="fas fa-paper-plane me-2"></i> GỬI YÊU CẦU
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
